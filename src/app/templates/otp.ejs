<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Your Collab Pro Verification Code</title>
    <style>
      /* Reset styles for email clients */
      body,
      p,
      h1,
      h2,
      h3 {
        margin: 0;
        padding: 0;
      }
      body {
        font-family:
          -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica,
          Arial, sans-serif;
        background-color: #f4f4f5;
        color: #09090b;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }
      .container {
        max-width: 600px;
        margin: 40px auto;
        background-color: #ffffff;
        border-radius: 16px;
        overflow: hidden;
        box-shadow:
          0 4px 6px -1px rgba(0, 0, 0, 0.1),
          0 2px 4px -1px rgba(0, 0, 0, 0.06);
      }
      .header {
        background-color: #7c3aed; /* Collab Pro Primary Purple */
        padding: 32px 40px;
        text-align: center;
      }
      .logo-container {
        display: inline-block;
        background-color: rgba(255, 255, 255, 0.2);
        padding: 12px;
        border-radius: 12px;
        margin-bottom: 16px;
      }
      .header h1 {
        color: #ffffff;
        font-size: 24px;
        font-weight: 700;
        letter-spacing: -0.5px;
      }
      .content {
        padding: 40px;
      }
      .greeting {
        font-size: 18px;
        font-weight: 600;
        margin-bottom: 16px;
        color: #09090b;
      }
      .message {
        color: #71717a;
        margin-bottom: 32px;
        font-size: 16px;
      }
      .otp-container {
        background-color: #f3f4f6;
        border: 1px solid #e4e4e7;
        border-radius: 12px;
        padding: 24px;
        text-align: center;
        margin-bottom: 32px;
      }
      .otp-code {
        font-family:
          "SFMono-Regular", Consolas, "Liberation Mono", Menlo, Courier,
          monospace;
        font-size: 36px;
        font-weight: 700;
        letter-spacing: 8px;
        color: #7c3aed;
        margin: 0;
      }
      .warning {
        font-size: 14px;
        color: #a1a1aa;
        text-align: center;
        margin-bottom: 0;
      }
      .footer {
        background-color: #fafafa;
        border-top: 1px solid #f4f4f5;
        padding: 24px 40px;
        text-align: center;
      }
      .footer p {
        color: #a1a1aa;
        font-size: 13px;
        margin-bottom: 8px;
      }
      .footer a {
        color: #7c3aed;
        text-decoration: none;
        font-weight: 500;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="header">
        <div class="logo-container">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="28"
            height="28"
            viewBox="0 0 24 24"
            fill="#ffffff"
            stroke="#ffffff"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
          </svg>
        </div>
        <h1>Collab Pro</h1>
      </div>

      <div class="content">
        <p class="greeting">Hello <%= name %>,</p>
        <p class="message">
          We received a request to verify your email address. Use the security
          code below to complete your request. This code will expire in
          <strong>2 minutes</strong>.
        </p>

        <div class="otp-container">
          <p class="otp-code"><%= otp %></p>
        </div>

        <p class="warning">
          If you didn't request this code, you can safely ignore this email.
          Someone else might have typed your email address by mistake.
        </p>
      </div>

      <div class="footer">
        <p>Securely sent by <a href="#">Collab Pro Security</a></p>
        <p>
          &copy; <%= new Date().getFullYear() %> Collab Pro. All rights
          reserved.
        </p>
      </div>
    </div>
  </body>
</html>
