// ============================================================
//  Prisma Schema
//  Project  : Multi-Tenant SaaS Collaboration Platform
//  Source   : Advanced-SaaS-ERD-with-Payment.drawio
//  Database : PostgreSQL
//  Tables   : 22  |  Relations : 30  |  Enums : 7
// ============================================================

generator client {
  provider = "prisma-client"
  output   = "../../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  CANCELED

  @@map("task_status")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
  DELETED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT

  @@map("task_priority")
}

enum ProjectMemberRole {
  OWNER
  MANAGER
  CONTRIBUTOR
  VIEWER

  @@map("project_member_role")
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_UPDATED
  COMMENT_ADDED
  MEMBER_JOINED
  MEMBER_REMOVED
  INVITATION_SENT
  SUBSCRIPTION_CHANGED
  INVOICE_PAID
  GENERAL

  @@map("notification_type")
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  PAUSED
  INCOMPLETE

  @@map("subscription_status")
}

enum BillingCycle {
  MONTHLY
  YEARLY

  @@map("billing_cycle")
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE

  @@map("invoice_status")
}

// ─────────────────────────────────────────────────────────────
// 1. USER
// ERD edges : → Organization (owner), Membership, ProjectMember,
//               Task (assignee), TaskComment, TaskAttachment,
//               Notification, ActivityLog (actor), File
// ─────────────────────────────────────────────────────────────

model User {
  id                 String     @id @default(uuid())
  name               String     @unique
  email              String
  image              String?    @map("avatar")
  emailVerified      Boolean    @default(false)
  status             UserStatus @default(ACTIVE)
  needPasswordChange Boolean    @default(false)
  isDeleted          Boolean    @default(false)
  deletedAt          DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  // Relations
  sessions           Session[]
  accounts           Account[]
  ownedOrganizations Organization[]   @relation("OrgOwner")
  memberships        Membership[]
  projectMembers     ProjectMember[]
  assignedTasks      Task[]           @relation("TaskAssignee")
  taskComments       TaskComment[]
  taskAttachments    TaskAttachment[] @relation("AttachmentUploader")
  notifications      Notification[]
  activityLogs       ActivityLog[]    @relation("ActivityActor")
  files              File[]           @relation("FileUploader")

  @@index([email], map: "idx_users_email")
  @@index([createdAt], map: "idx_users_created_at")
  @@map("users")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ─────────────────────────────────────────────────────────────
// 2. ORGANIZATION  (Tenant)
// ERD edges : → Role, Membership, Invitation, Project,
//               ActivityLog, ApiKey, Subscription (1:1)
// ─────────────────────────────────────────────────────────────

model Organization {
  id        String   @id @default(cuid()) @map("id")
  ownerId   String   @map("owner_id")
  name      String   @map("name")
  slug      String   @unique @map("slug")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  owner        User          @relation("OrgOwner", fields: [ownerId], references: [id])
  roles        Role[]
  memberships  Membership[]
  invitations  Invitation[]
  projects     Project[]
  activityLogs ActivityLog[]
  apiKeys      ApiKey[]
  subscription Subscription?

  @@index([slug], map: "idx_organizations_slug")
  @@index([ownerId], map: "idx_organizations_owner_id")
  @@map("organizations")
}

// ─────────────────────────────────────────────────────────────
// 3. ROLE
// ERD edges : → RolePermission, Membership, Invitation
// ─────────────────────────────────────────────────────────────

model Role {
  id             String @id @default(cuid()) @map("id")
  organizationId String @map("organization_id")
  name           String @map("name")

  // Relations
  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  rolePermissions RolePermission[]
  memberships     Membership[]
  invitations     Invitation[]

  @@unique([organizationId, name], map: "uq_role_org_name")
  @@index([organizationId], map: "idx_roles_organization_id")
  @@map("roles")
}

// ─────────────────────────────────────────────────────────────
// 4. PERMISSION
// ERD edges : → RolePermission
// ─────────────────────────────────────────────────────────────

model Permission {
  id       String @id @default(cuid()) @map("id")
  action   String @map("action") // e.g. "create", "read", "delete"
  resource String @map("resource") // e.g. "project", "task"

  // Relations
  rolePermissions RolePermission[]

  @@unique([action, resource], map: "uq_permission_action_resource")
  @@map("permissions")
}

// ─────────────────────────────────────────────────────────────
// 5. ROLE PERMISSION  (pivot — Roles ↔ Permissions)
// ERD edges : Role → RolePermission, Permission → RolePermission
// Composite PK: [roleId, permissionId]
// ─────────────────────────────────────────────────────────────

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  // Relations
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([roleId], map: "idx_role_permissions_role_id")
  @@index([permissionId], map: "idx_role_permissions_permission_id")
  @@map("role_permissions")
}

// ─────────────────────────────────────────────────────────────
// 6. MEMBERSHIP  (Users ↔ Organizations, carries Role)
// ERD edges : User → Membership, Organization → Membership,
//             Role → Membership
// ─────────────────────────────────────────────────────────────

model Membership {
  id             String   @id @default(cuid()) @map("id")
  userId         String   @map("user_id")
  organizationId String   @map("organization_id")
  roleId         String   @map("role_id")
  joinedAt       DateTime @default(now()) @map("joined_at")

  // Relations
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role         Role         @relation(fields: [roleId], references: [id])

  @@unique([userId, organizationId], map: "uq_membership_user_org")
  @@index([userId], map: "idx_memberships_user_id")
  @@index([organizationId], map: "idx_memberships_organization_id")
  @@index([roleId], map: "idx_memberships_role_id")
  @@map("memberships")
}

// ─────────────────────────────────────────────────────────────
// 7. INVITATION
// ERD edges : Organization → Invitation, Role → Invitation
// ─────────────────────────────────────────────────────────────

model Invitation {
  id             String    @id @default(cuid()) @map("id")
  organizationId String    @map("organization_id")
  roleId         String    @map("role_id")
  email          String    @map("email")
  token          String    @unique @default(cuid()) @map("token")
  acceptedAt     DateTime? @map("accepted_at")
  expiresAt      DateTime? @map("expires_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role         Role         @relation(fields: [roleId], references: [id])

  @@index([organizationId], map: "idx_invitations_organization_id")
  @@index([token], map: "idx_invitations_token")
  @@index([email], map: "idx_invitations_email")
  @@map("invitations")
}

// ─────────────────────────────────────────────────────────────
// 8. PROJECT
// ERD edges : Organization → Project
//             Project → ProjectMember, Task, Label
// ─────────────────────────────────────────────────────────────

model Project {
  id             String   @id @default(cuid()) @map("id")
  organizationId String   @map("organization_id")
  name           String   @map("name")
  description    String?  @map("description")
  createdBy      String   @map("created_by")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projectMembers ProjectMember[]
  tasks          Task[]
  labels         Label[]

  @@index([organizationId], map: "idx_projects_organization_id")
  @@index([createdBy], map: "idx_projects_created_by")
  @@map("projects")
}

// ─────────────────────────────────────────────────────────────
// 9. PROJECT MEMBER  (pivot — Projects ↔ Users)
// ERD edges : Project → ProjectMember, User → ProjectMember
// ─────────────────────────────────────────────────────────────

model ProjectMember {
  id        String            @id @default(cuid()) @map("id")
  projectId String            @map("project_id")
  userId    String            @map("user_id")
  role      ProjectMemberRole @default(CONTRIBUTOR) @map("role")
  joinedAt  DateTime          @default(now()) @map("joined_at")

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId], map: "uq_project_member_user")
  @@index([projectId], map: "idx_project_members_project_id")
  @@index([userId], map: "idx_project_members_user_id")
  @@map("project_members")
}

// ─────────────────────────────────────────────────────────────
// 10. TASK
// ERD edges : Project → Task, User → Task (assignee)
//             Task → TaskComment, TaskAttachment, TaskLabel
// ─────────────────────────────────────────────────────────────

model Task {
  id         String       @id @default(cuid()) @map("id")
  projectId  String       @map("project_id")
  assignedTo String?      @map("assigned_to")
  title      String       @map("title")
  status     TaskStatus   @default(TODO) @map("status")
  priority   TaskPriority @default(MEDIUM) @map("priority")
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  // Relations
  project     Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee    User?            @relation("TaskAssignee", fields: [assignedTo], references: [id], onDelete: SetNull)
  comments    TaskComment[]
  attachments TaskAttachment[]
  taskLabels  TaskLabel[]

  @@index([projectId], map: "idx_tasks_project_id")
  @@index([assignedTo], map: "idx_tasks_assigned_to")
  @@index([status], map: "idx_tasks_status")
  @@index([priority], map: "idx_tasks_priority")
  @@map("tasks")
}

// ─────────────────────────────────────────────────────────────
// 11. TASK COMMENT
// ERD edges : Task → TaskComment, User → TaskComment
// ─────────────────────────────────────────────────────────────

model TaskComment {
  id        String   @id @default(cuid()) @map("id")
  taskId    String   @map("task_id")
  userId    String   @map("user_id")
  message   String   @map("message")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId], map: "idx_task_comments_task_id")
  @@index([userId], map: "idx_task_comments_user_id")
  @@map("task_comments")
}

// ─────────────────────────────────────────────────────────────
// 12. TASK ATTACHMENT
// ERD edges : Task → TaskAttachment, User → TaskAttachment
// ─────────────────────────────────────────────────────────────

model TaskAttachment {
  id         String   @id @default(cuid()) @map("id")
  taskId     String   @map("task_id")
  uploadedBy String   @map("uploaded_by")
  fileUrl    String   @map("file_url")
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  task     Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploader User @relation("AttachmentUploader", fields: [uploadedBy], references: [id])

  @@index([taskId], map: "idx_task_attachments_task_id")
  @@index([uploadedBy], map: "idx_task_attachments_uploaded_by")
  @@map("task_attachments")
}

// ─────────────────────────────────────────────────────────────
// 13. LABEL
// ERD edges : Project → Label, Label → TaskLabel
// ─────────────────────────────────────────────────────────────

model Label {
  id        String @id @default(cuid()) @map("id")
  projectId String @map("project_id")
  name      String @map("name")
  color     String @map("color") // hex e.g. "#3498db"

  // Relations
  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskLabels TaskLabel[]

  @@unique([projectId, name], map: "uq_label_project_name")
  @@index([projectId], map: "idx_labels_project_id")
  @@map("labels")
}

// ─────────────────────────────────────────────────────────────
// 14. TASK LABEL  (pivot — Tasks ↔ Labels)
// ERD edges : Task → TaskLabel, Label → TaskLabel
// Composite PK: [taskId, labelId]
// ─────────────────────────────────────────────────────────────

model TaskLabel {
  taskId  String @map("task_id")
  labelId String @map("label_id")

  // Relations
  task  Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([taskId, labelId])
  @@index([taskId], map: "idx_task_labels_task_id")
  @@index([labelId], map: "idx_task_labels_label_id")
  @@map("task_labels")
}

// ─────────────────────────────────────────────────────────────
// 15. NOTIFICATION
// ERD edges : User → Notification
// ─────────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid()) @map("id")
  userId    String           @map("user_id")
  type      NotificationType @default(GENERAL) @map("type")
  title     String           @map("title")
  body      String?          @map("body")
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_notifications_user_id")
  @@index([isRead], map: "idx_notifications_is_read")
  @@index([createdAt], map: "idx_notifications_created_at")
  @@map("notifications")
}

// ─────────────────────────────────────────────────────────────
// 16. ACTIVITY LOG
// ERD edges : Organization → ActivityLog, User → ActivityLog
// ─────────────────────────────────────────────────────────────

model ActivityLog {
  id             String   @id @default(cuid()) @map("id")
  organizationId String   @map("organization_id")
  actorId        String   @map("actor_id")
  action         String   @map("action")
  metadata       Json?    @map("metadata")
  createdAt      DateTime @default(now()) @map("created_at")

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actor        User         @relation("ActivityActor", fields: [actorId], references: [id])

  @@index([organizationId], map: "idx_activity_logs_organization_id")
  @@index([actorId], map: "idx_activity_logs_actor_id")
  @@index([action], map: "idx_activity_logs_action")
  @@index([createdAt], map: "idx_activity_logs_created_at")
  @@map("activity_logs")
}

// ─────────────────────────────────────────────────────────────
// 17. FILE
// ERD edges : User → File (uploader)
// ─────────────────────────────────────────────────────────────

model File {
  id         String   @id @default(cuid()) @map("id")
  uploadedBy String   @map("uploaded_by")
  url        String   @map("url")
  mimeType   String?  @map("mime_type")
  sizeBytes  Int?     @map("size_bytes")
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  uploader User @relation("FileUploader", fields: [uploadedBy], references: [id])

  @@index([uploadedBy], map: "idx_files_uploaded_by")
  @@index([mimeType], map: "idx_files_mime_type")
  @@map("files")
}

// ─────────────────────────────────────────────────────────────
// 18. API KEY
// ERD edges : Organization → ApiKey
// ─────────────────────────────────────────────────────────────

model ApiKey {
  id             String    @id @default(cuid()) @map("id")
  organizationId String    @map("organization_id")
  name           String    @map("name")
  keyHash        String    @unique @map("key_hash")
  keyPrefix      String    @map("key_prefix")
  isActive       Boolean   @default(true) @map("is_active")
  lastUsedAt     DateTime? @map("last_used_at")
  expiresAt      DateTime? @map("expires_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId], map: "idx_api_keys_organization_id")
  @@index([isActive], map: "idx_api_keys_is_active")
  @@map("api_keys")
}

// ─────────────────────────────────────────────────────────────
// 19. PLAN
// ERD edges : Plan → Subscription, Plan → PlanFeature
// ─────────────────────────────────────────────────────────────

model Plan {
  id           String   @id @default(cuid()) @map("id")
  name         String   @map("name")
  slug         String   @unique @map("slug")
  description  String?  @map("description")
  priceMonthly Decimal  @map("price_monthly") @db.Decimal(10, 2)
  priceYearly  Decimal  @map("price_yearly") @db.Decimal(10, 2)
  currency     String   @default("USD") @map("currency")
  trialDays    Int      @default(14) @map("trial_days")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  subscriptions Subscription[]
  features      PlanFeature[]

  @@index([isActive], map: "idx_plans_is_active")
  @@index([slug], map: "idx_plans_slug")
  @@map("plans")
}

// ─────────────────────────────────────────────────────────────
// 20. SUBSCRIPTION  (1:1 with Organization)
// ERD edges : Organization → Subscription (unique / 1:1)
//             Plan → Subscription
//             Subscription → Invoice
// ─────────────────────────────────────────────────────────────

model Subscription {
  id                   String             @id @default(cuid()) @map("id")
  organizationId       String             @unique @map("organization_id")
  planId               String             @map("plan_id")
  status               SubscriptionStatus @default(TRIALING) @map("status")
  billingCycle         BillingCycle       @default(MONTHLY) @map("billing_cycle")
  currentPeriodStart   DateTime           @map("current_period_start")
  currentPeriodEnd     DateTime           @map("current_period_end")
  trialEndsAt          DateTime?          @map("trial_ends_at")
  canceledAt           DateTime?          @map("canceled_at")
  cancelAtPeriodEnd    Boolean            @default(false) @map("cancel_at_period_end")
  stripeCustomerId     String?            @unique @map("stripe_customer_id")
  stripeSubscriptionId String?            @unique @map("stripe_subscription_id")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan         Plan         @relation(fields: [planId], references: [id])
  invoices     Invoice[]

  @@index([organizationId], map: "idx_subscriptions_organization_id")
  @@index([planId], map: "idx_subscriptions_plan_id")
  @@index([status], map: "idx_subscriptions_status")
  @@index([currentPeriodEnd], map: "idx_subscriptions_period_end")
  @@map("subscriptions")
}

// ─────────────────────────────────────────────────────────────
// 21. INVOICE
// ERD edges : Subscription → Invoice
// ─────────────────────────────────────────────────────────────

model Invoice {
  id              String        @id @default(cuid()) @map("id")
  subscriptionId  String        @map("subscription_id")
  status          InvoiceStatus @default(DRAFT) @map("status")
  amountDue       Decimal       @map("amount_due") @db.Decimal(10, 2)
  amountPaid      Decimal       @default(0) @map("amount_paid") @db.Decimal(10, 2)
  currency        String        @default("USD") @map("currency")
  periodStart     DateTime      @map("period_start")
  periodEnd       DateTime      @map("period_end")
  dueDate         DateTime?     @map("due_date")
  paidAt          DateTime?     @map("paid_at")
  stripeInvoiceId String?       @unique @map("stripe_invoice_id")
  invoicePdfUrl   String?       @map("invoice_pdf_url")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  // Relations
  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId], map: "idx_invoices_subscription_id")
  @@index([status], map: "idx_invoices_status")
  @@index([paidAt], map: "idx_invoices_paid_at")
  @@map("invoices")
}

// ─────────────────────────────────────────────────────────────
// 22. PLAN FEATURE
// ERD edges : Plan → PlanFeature
// ─────────────────────────────────────────────────────────────

model PlanFeature {
  id          String   @id @default(cuid()) @map("id")
  planId      String   @map("plan_id")
  name        String   @map("name")
  description String?  @map("description")
  limitValue  Int?     @map("limit_value")
  isEnabled   Boolean  @default(true) @map("is_enabled")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, name], map: "uq_plan_feature_plan_name")
  @@index([planId], map: "idx_plan_features_plan_id")
  @@index([isEnabled], map: "idx_plan_features_is_enabled")
  @@map("plan_features")
}
